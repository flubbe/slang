{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Slang",
  "scopeName": "source.slang",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#directives"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#macros"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.slang",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.slang",
          "match": "//.*$"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "meta.preprocessor.attribute.slang",
          "begin": "#\\[",
          "end": "\\]",
          "patterns": [
            {
              "name": "entity.name.function.preprocessor.slang",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
            },
            {
              "name": "punctuation.separator.key-value.slang",
              "match": "[:,]"
            },
            {
              "name": "string.quoted.double.slang",
              "begin": "\"",
              "end": "\"",
              "patterns": [
                {
                  "name": "constant.character.escape.slang",
                  "match": "\\\\(?:[\\\\\"nrtfv]|x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]+\\})"
                }
              ]
            },
            {
              "name": "constant.numeric.slang",
              "match": "\\b\\d+(?:\\.\\d+)?\\b"
            }
          ]
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.slang",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.slang",
          "match": "\\\\(?:[\\\\\"nrtfv]|x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]+\\})"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.slang",
          "match": "\\b\\d+\\.\\d+(?:[eE][+-]?\\d+)?(?:f32|f64)?\\b"
        },
        {
          "name": "constant.numeric.float.slang",
          "match": "\\b\\d+\\.(?:[eE][+-]?\\d+)?(?:f32|f64)?\\b"
        },
        {
          "name": "constant.numeric.integer.slang",
          "match": "\\b\\d+(?:i8|i16|i32|i64|u8|u16|u32|u64)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.slang",
          "match": "\\b(?:if|else|while|break|continue|return)\\b"
        },
        {
          "name": "keyword.declaration.slang",
          "match": "\\b(?:import|let|struct|fn|macro)\\b"
        },
        {
          "name": "keyword.operator.word.slang",
          "match": "\\b(?:as)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.builtin.slang",
          "match": "\\b(?:void|str|i8|i16|i32|i64|u8|u16|u32|u64|f32|f64)\\b"
        },
        {
          "name": "storage.type.user.slang",
          "match": "(?<=:\\s*)\\b[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "storage.type.user.slang",
          "match": "(?<=->\\s*)\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.definition.slang",
          "match": "\\bfn\\s+([A-Za-z_][A-Za-z0-9_]*)\\b"
        },
        {
          "name": "entity.name.function.call.slang",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "macros": {
      "patterns": [
        {
          "name": "entity.name.function.macro.slang",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*!\\b"
        },
        {
          "name": "variable.parameter.macro.slang",
          "match": "\\$[A-Za-z_][A-Za-z0-9_]*"
        },
        {
          "name": "keyword.operator.macro.ellipsis.slang",
          "match": "\\.\\.\\."
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.slang",
          "match": "\\b(?:null)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.slang",
          "match": "(?:\\+\\+|--|==|!=|<=|>=|<<=|>>=|&&|\\|\\||\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<|>>|->|=>|::|[+\\-*/%&|^~!=<>?:.])"
        },
        {
          "name": "punctuation.separator.slang",
          "match": "[,;]"
        }
      ]
    }
  }
}
